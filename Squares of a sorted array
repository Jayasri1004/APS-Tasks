import java.util.*;
class Solution
{
    public int[] sortedSquares(int nums[])
    {
        int[] res=new int[nums.length];
        for(int l=0,r=nums.length-1,i=r;l<=r;)
        {
            res[i--]=nums[l]*nums[l]>nums[r]*nums[r]
            ?nums[l]*nums[l++]
            :nums[r]*nums[r--];
        }
return res;
    }
}
